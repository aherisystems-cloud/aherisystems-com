---
interface Props {
  variant?: "light" | "dark" | "teal";
  title?: string;
  subtitle?: string;
}

const {
  variant = "teal",
  title,
  subtitle,
} = Astro.props;

const defaults = {
  teal: {
    title: "Every week without Automation & AI, your competitors pull further ahead",
    subtitle: "5,000+ MSMEs already fixed this. Get the exact Automation & AI moves that save time, cut costs and grow revenue. Free. Every Monday. No fluff.",
  },
  dark: {
    title: "You are losing hours and money every day you delay",
    subtitle: "The Automation & AI strategies your competitors are quietly using — delivered to your inbox every Monday. Free.",
  },
  light: {
    title: "What are you waiting for?",
    subtitle: "The Automation & AI tips saving MSMEs 5+ hours and thousands every month — delivered free every Monday.",
  },
};

const finalTitle = title || defaults[variant].title;
const finalSubtitle = subtitle || defaults[variant].subtitle;

const bgClass = {
  light: "bg-gray-50 border border-gray-200",
  dark: "bg-[#1A2F4E]",
  teal: "bg-[#0ABFB8]",
}[variant];

const titleClass = {
  light: "text-[#1A2F4E]",
  dark: "text-white",
  teal: "text-white",
}[variant];

const subtitleClass = {
  light: "text-gray-500",
  dark: "text-gray-300",
  teal: "text-white/90",
}[variant];

const labelClass = {
  light: "text-[#0ABFB8]",
  dark: "text-[#0ABFB8]",
  teal: "text-white/70",
}[variant];

const noteClass = {
  light: "text-gray-400",
  dark: "text-gray-500",
  teal: "text-white/60",
}[variant];
---

<div class={"rounded-2xl px-6 py-8 " + bgClass}>

  <div class="text-center mb-6">
    <p class={"text-xs font-bold tracking-widest uppercase mb-3 " + labelClass}>
      FREE — AUTOMATION & AI WEEKLY
    </p>
    <h3 class={"font-extrabold text-xl leading-snug mb-3 " + titleClass}>{finalTitle}</h3>
    <p class={"text-sm leading-relaxed " + subtitleClass}>{finalSubtitle}</p>
  </div>

  <div class="ml-form-wrapper">
    <style type="text/css">
      .ml-form-wrapper .ml-form-embedContainer {
        box-sizing: border-box;
        width: 100% !important;
      }
      .ml-form-wrapper .ml-form-embedWrapper {
        background-color: transparent !important;
        border: none !important;
        box-shadow: none !important;
        width: 100% !important;
        max-width: 100% !important;
        display: block !important;
      }
      .ml-form-wrapper .ml-form-embedBody {
        padding: 0 !important;
      }
      .ml-form-wrapper .ml-form-embedContent {
        display: none !important;
      }
      .ml-form-wrapper .ml-form-horizontalRow {
        display: flex;
        gap: 8px;
        width: 100%;
      }
      .ml-form-wrapper .ml-input-horizontal {
        flex: 1;
      }
      .ml-form-wrapper .ml-form-horizontalRow input[type="email"] {
        width: 100% !important;
        padding: 12px 16px !important;
        border-radius: 12px !important;
        border: 1px solid #e5e7eb !important;
        font-size: 14px !important;
        color: #1f2937 !important;
        background-color: #ffffff !important;
        box-sizing: border-box !important;
      }
      .ml-form-wrapper .ml-form-horizontalRow input[type="email"]:focus {
        outline: none !important;
        border-color: #0ABFB8 !important;
        box-shadow: 0 0 0 2px rgba(10,191,184,0.2) !important;
      }
      .ml-form-wrapper .ml-button-horizontal button,
      .ml-form-wrapper .ml-mobileButton-horizontal button {
        background-color: #1A2F4E !important;
        color: #ffffff !important;
        border: none !important;
        border-radius: 12px !important;
        padding: 12px 24px !important;
        font-size: 14px !important;
        font-weight: 700 !important;
        cursor: pointer !important;
        white-space: nowrap !important;
        transition: background-color 0.2s !important;
      }
      .ml-form-wrapper .ml-button-horizontal button:hover,
      .ml-form-wrapper .ml-mobileButton-horizontal button:hover {
        background-color: #0ABFB8 !important;
      }
      .ml-form-wrapper .ml-form-embedSubmit button {
        background-color: #1A2F4E !important;
        color: #ffffff !important;
        border: none !important;
        border-radius: 12px !important;
        padding: 12px 24px !important;
        font-size: 14px !important;
        font-weight: 700 !important;
        cursor: pointer !important;
        width: 100% !important;
        transition: background-color 0.2s !important;
      }
      .ml-form-wrapper .ml-form-embedSubmit button:hover {
        background-color: #0ABFB8 !important;
      }
      .ml-form-wrapper .ml-form-checkboxRow {
        margin-top: 8px !important;
      }
      .ml-form-wrapper .ml-form-checkboxRow .label-description p {
        font-size: 11px !important;
        color: #9ca3af !important;
      }
      .ml-form-wrapper .ml-form-recaptcha {
        margin-top: 8px !important;
      }
      .ml-form-wrapper .ml-form-successBody {
        text-align: center;
        padding: 16px 0 !important;
      }
      .ml-form-wrapper .ml-form-successBody h4 {
        color: #1A2F4E !important;
        font-size: 18px !important;
        font-weight: 700 !important;
        margin-bottom: 8px !important;
      }
      .ml-form-wrapper .ml-form-successBody p {
        color: #6b7280 !important;
        font-size: 13px !important;
      }
      @media only screen and (max-width: 480px) {
        .ml-form-wrapper .ml-form-horizontalRow {
          flex-direction: column !important;
        }
      }
    </style>

    <div id="mlb2-38448893" class="ml-form-embedContainer ml-subscribe-form ml-subscribe-form-38448893">
      <div class="ml-form-align-center">
        <div class="ml-form-embedWrapper embedForm">
          <div class="ml-form-embedBody ml-form-embedBodyHorizontal row-form">
            <div class="ml-form-embedContent" style="display:none"></div>
            <form class="ml-block-form" action="https://assets.mailerlite.com/jsonp/2189648/forms/181888158855595828/subscribe" data-code="" method="post" target="_blank">
              <div class="ml-form-formContent horozintalForm">
                <div class="ml-form-horizontalRow">
                  <div class="ml-input-horizontal">
                    <div style="width:100%" class="horizontal-fields">
                      <div class="ml-field-group ml-field-email ml-validate-email ml-validate-required">
                        <input type="email" class="form-control" data-inputmask="" name="fields[email]" placeholder="Enter your email address" autocomplete="email" />
                      </div>
                    </div>
                  </div>
                  <div class="ml-button-horizontal primary">
                    <button type="submit" class="primary">Join Free</button>
                    <button disabled="disabled" style="display:none" type="button" class="loading">
                      <div class="ml-form-embedSubmitLoad"></div>
                      <span class="sr-only">Loading...</span>
                    </button>
                  </div>
                </div>
              </div>
              <div class="ml-form-checkboxRow ml-validate-required">
                <label class="checkbox">
                  <input type="checkbox" />
                  <div class="label-description">
                    <p>I agree to receive Automation & AI tips, deals and updates. No spam. Unsubscribe anytime.</p>
                  </div>
                </label>
              </div>
              <div class="ml-form-recaptcha ml-validate-required" style="float:left">
                <script src="https://www.google.com/recaptcha/api.js"></script>
                <div class="g-recaptcha" data-sitekey="6Lf1KHQUAAAAAFNKEX1hdSWCS3mRMv4FlFaNslaD"></div>
              </div>
              <input type="hidden" name="ml-submit" value="1" />
              <div class="ml-mobileButton-horizontal">
                <button type="submit" class="primary">Join Free</button>
                <button disabled="disabled" style="display:none" type="button" class="loading">
                  <div class="ml-form-embedSubmitLoad"></div>
                  <span class="sr-only">Loading...</span>
                </button>
              </div>
              <input type="hidden" name="anticsrf" value="true" />
            </form>
          </div>
          <div class="ml-form-successBody row-success" style="display:none">
            <div class="ml-form-successContent">
              <h4>You are in. Welcome.</h4>
              <p>Your first Automation & AI tip lands Monday. Check your inbox for a confirmation email.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://groot.mailerlite.com/js/w/webforms.min.js?v95037e5bac78f29ed026832ca21a7c7b" type="text/javascript"></script>
    <script is:inline>
      function ml_webform_success_38448893() {
        var $ = ml_jQuery || jQuery;
        $('.ml-subscribe-form-38448893 .row-success').show();
        $('.ml-subscribe-form-38448893 .row-form').hide();
      }
    </script>
  </div>

  <p class={"text-xs text-center mt-4 " + noteClass}>
    No spam. Unsubscribe anytime. Join 5,000+ MSMEs already ahead.
  </p>
</div>