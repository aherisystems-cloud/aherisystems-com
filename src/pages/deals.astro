  },
  {
    name: "ClickUp",
    tagline: "Replace every project management tool with one",
    offer: "Free plan — unlimited tasks and unlimited members",
    original_price: "$7/mo",
    deal_price: "$0",
    saving: "$84/year",
    category: "Project Management",
    badge: "Unlimited Tasks Free",
    badgeColor: "#7C3AED",
    highlight: false,
    affiliate_url: "https://clickup.com/?via=aherisystems",
    slug: "clickup",
    expires: null,
