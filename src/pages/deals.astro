    category: "CRM",
    badge: "Free Forever",
    badgeColor: "#DC2626",
    highlight: true,
    affiliate_url: "https://hubspot.com/?via=aherisystems",
    slug: "hubspot",
    expires: null,
    color: "#FF7A59",
    why: "The most powerful free CRM available. No catch, no time limit. Scales with your business.",
  },
  {
    name: "Notion",
    tagline: "One workspace for your entire business",
    offer: "Free plan — unlimited pages, databases and blocks for individuals",
    original_price: "$8/mo",
    deal_price: "$0",
    saving: "$96/year",
    category: "Productivity",
