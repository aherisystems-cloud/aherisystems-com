    category: "Automation",
    badge: "Best Free Tier",
    badgeColor: "#059669",
    highlight: true,
    affiliate_url: "https://make.com/?via=aherisystems",
    slug: "make",
    expires: null,
    color: "#6D00CC",
    why: "Most generous free tier of any automation tool. 10x more operations than Zapier's free plan.",
  },
  {
    name: "HubSpot CRM",
