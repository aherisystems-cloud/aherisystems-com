  },
  {
    name: "Make",
    tagline: "Visual automation that handles complex workflows your business runs on",
    description: "Make (formerly Integromat) gives you a visual canvas to build powerful automations. More flexible than Zapier, better value for complex workflows.",
    category: "Automation",
