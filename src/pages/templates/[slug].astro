---
import Layout from "../../layouts/Layout.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import templates from "../../data/templates.js";
import tools from "../../data/tools.js";
import systems from "../../data/systems.js";

export async function getStaticPaths() {
  return templates.map((t) => ({
    params: { slug: t.slug },
    props: { template: t },
  }));
}

const { template: tpl } = Astro.props;

const featuredTools = tpl.tools_featured
  .map((slug) => tools.find((t) => t.slug === slug))
  .filter(Boolean);

const relatedTemplates = templates.filter((t) =>
  tpl.related_templates.includes(t.slug)
);

const relatedSystems = systems.filter((s) =>
  tpl.related_systems.includes(s.slug)
);

const schema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": tpl.title,
  "description": tpl.tagline,
  "author": { "@type": "Person", "name": "Rit Andubi", "url": "https://ritandubi.com" },
  "publisher": { "@type": "Organization", "name": "Aheri Systems", "url": "https://aherisystems.com" },
  "isAccessibleForFree": true,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout
  title={tpl.title + " — Free Download"}
  description={tpl.tagline + ". Free download. " + tpl.time_to_use + " to implement. Built for MSMEs and solo entrepreneurs."}
>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <!-- BREADCRUMB -->
  <div class="bg-gray-50 border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 py-3">
      <p class="text-xs text-gray-400">
        <a href="/" class="hover:text-[#0ABFB8] transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/templates" class="hover:text-[#0ABFB8] transition-colors">Templates</a>
        <span class="mx-2">/</span>
        <span class="text-gray-600 font-medium">{tpl.title}</span>
      </p>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-[#1A2F4E] pt-14 pb-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row items-start gap-10">

        <!-- Left -->
        <div class="flex-1">
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs font-bold px-2.5 py-1 rounded-full text-white" style={"background-color: " + tpl.badgeColor}>{tpl.badge}</span>
            <span class="text-xs bg-white/10 text-gray-300 border border-white/20 px-2.5 py-1 rounded-full">{tpl.type}</span>
            <span class="text-xs bg-white/10 text-gray-300 border border-white/20 px-2.5 py-1 rounded-full">{tpl.format}</span>
            <span class="text-xs bg-green-500/20 text-green-400 border border-green-500/30 px-2.5 py-1 rounded-full font-bold">Free Download</span>
          </div>

          <h1 class="text-3xl md:text-4xl font-extrabold text-white leading-tight mb-4">{tpl.title}</h1>
          <p class="text-gray-300 text-lg mb-6">{tpl.tagline}</p>

          <div class="grid grid-cols-3 gap-3 mb-6">
            {[
              { label: "Time Saved", value: tpl.outcomes.save_time.metric, color: "#0ABFB8" },
              { label: "Money Saved", value: tpl.outcomes.save_money.metric, color: "#059669" },
              { label: "Time to Use", value: tpl.time_to_use, color: "#D97706" },
            ].map((o) => (
              <div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
                <p class="font-extrabold text-base" style={"color: " + o.color}>{o.value}</p>
                <p class="text-gray-400 text-xs mt-1">{o.label}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-wrap gap-3 text-sm text-gray-400">
            <span>Category: <strong class="text-white">{tpl.category}</strong></span>
            <span class="text-gray-600">|</span>
            <span>Format: <strong class="text-white">{tpl.format}</strong></span>
            <span class="text-gray-600">|</span>
            <span>Cost: <strong class="text-green-400">Free</strong></span>
          </div>
        </div>

        <!-- Right: Download CTA -->
        <div class="w-full lg:w-72 flex-shrink-0">
          <div class="bg-white rounded-2xl p-6 shadow-xl">
            <div class="text-center mb-5">
              <span class="text-xs font-bold text-green-600 bg-green-50 border border-green-200 px-3 py-1 rounded-full">100% Free Download</span>
              <p class="text-[#1A2F4E] font-extrabold text-xl mt-3 mb-1">{tpl.title}</p>
              <p class="text-gray-500 text-xs">{tpl.format} — {tpl.time_to_use} to implement</p>
            </div>
            <div class="border-t border-gray-100 pt-4 mb-5">
              <p class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3">What you get:</p>
              <ul class="space-y-2">
                {tpl.what_you_get.slice(0, 4).map((item) => (
                  <li class="flex items-start gap-2 text-xs text-gray-600">
                    <span class="text-[#0ABFB8] font-bold mt-0.5 flex-shrink-0">✓</span>
                    {item}
                  </li>
                ))}
                {tpl.what_you_get.length > 4 && (
                  <li class="text-xs text-gray-400">+{tpl.what_you_get.length - 4} more inside</li>
                )}
              </ul>
            </div>
            <button
              class="ml-newsletter-btn w-full bg-[#0ABFB8] hover:bg-[#09A8A2] text-white font-extrabold py-4 rounded-xl transition-colors text-sm cursor-pointer"
              onclick="ml('show', 'Z8IoNZ', true)"
            >
              Download Free — Get Instant Access
            </button>
            <p class="text-center text-gray-400 text-xs mt-3">Subscribe to get access. Unsubscribe anytime.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <div class="max-w-4xl mx-auto px-4 py-12 space-y-12">

    <!-- WHAT IS IT -->
    <section>
      <h2 class="text-2xl font-extrabold text-[#1A2F4E] mb-4">What Is This Template?</h2>
      <p class="text-gray-600 leading-relaxed text-base">{tpl.description}</p>
    </section>

    <!-- OUTCOME SCORES -->
    <section>
      <h2 class="text-2xl font-extrabold text-[#1A2F4E] mb-6">What This Template Does for Your Business</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[
          { label: "Save Time", color: "#0ABFB8", bg: "bg-[#0ABFB8]", lightBg: "bg-[#0ABFB8]/10", border: "border-[#0ABFB8]/30", data: tpl.outcomes.save_time },
          { label: "Save Money", color: "#059669", bg: "bg-[#059669]", lightBg: "bg-[#059669]/10", border: "border-[#059669]/30", data: tpl.outcomes.save_money },
          { label: "Make Money", color: "#D97706", bg: "bg-[#D97706]", lightBg: "bg-[#D97706]/10", border: "border-[#D97706]/30", data: tpl.outcomes.make_money },
        ].map((o) => (
          <div class={`rounded-xl border p-5 ${o.lightBg} ${o.border}`}>
            <div class="flex items-center justify-between mb-3">
              <span class="text-sm font-extrabold text-gray-700 uppercase tracking-wide">{o.label}</span>
              <span class="text-sm font-extrabold" style={"color: " + o.color}>{o.data.metric}</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2 mb-3">
              <div class={`h-2 rounded-full ${o.bg}`} style={"width: " + (o.data.score * 10) + "%"}></div>
            </div>
            <p class="text-xs text-gray-600 leading-relaxed">{o.data.detail}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section>
      <h2 class="text-2xl font-extrabold text-[#1A2F4E] mb-6">Everything Included in This Template</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tpl.what_you_get.map((item) => (
          <div class="flex items-start gap-3 bg-gray-50 border border-gray-100 rounded-lg px-4 py-3">
            <span class="w-5 h-5 bg-[#0ABFB8] rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0 mt-0.5">✓</span>
            <span class="text-gray-700 text-sm">{item}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- WHO IT IS FOR -->
    <section>
      <h2 class="text-2xl font-extrabold text-[#1A2F4E] mb-4">Who This Template Is For</h2>
      <div class="space-y-2">
        {tpl.best_for.map((item) => (
          <div class="flex items-center gap-3 bg-white border border-gray-200 rounded-lg px-4 py-3">
            <span class="text-[#0ABFB8] font-bold flex-shrink-0">✓</span>
            <span class="text-gray-700 text-sm">{item}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- DOWNLOAD CTA INLINE -->
    <section class="bg-[#0ABFB8]/10 border-2 border-[#0ABFB8] rounded-2xl p-6 text-center">
      <h2 class="text-2xl font-extrabold text-[#1A2F4E] mb-2">Ready to implement this today?</h2>
      <p class="text-gray-500 mb-5">Subscribe free and get instant access. Unsubscribe anytime.</p>
      <button
        class="ml-newsletter-btn bg-[#0ABFB8] hover:bg-[#09A8A2] text-white font-extrabold px-10 py-4 rounded-xl transition-colors text-base cursor-pointer"
        onclick="ml('show', 'Z8IoNZ', true)"
      >
        Download Free — Instant Access
      </button>
      <p class="text-gray-400 text-xs mt-3">Join 5,000+ MSMEs already saving time with Automation and AI</p>
    </section>

    <!-- TOOLS FEATURED -->
    {featuredTools.length > 0 && (
      <section>
        <h2 class="text-2xl font-extrabold text-[#1A2F4E] mb-2">Tools Featured in This Template</h2>
        <p class="text-gray-500 text-sm mb-5">This template works with the following tools. Click any to read the full review.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {featuredTools.map((tool) => (
            <a href={"/tools/" + tool.slug} class="flex items-center gap-4 bg-white border border-gray-200 hover:border-[#0ABFB8] rounded-xl p-4 transition-all group">
              <div class="w-10 h-10 bg-[#1A2F4E] rounded-xl flex items-center justify-center text-white font-extrabold flex-shrink-0">
                {tool.name[0]}
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-bold text-[#1A2F4E] group-hover:text-[#0ABFB8] transition-colors text-sm">{tool.name}</p>
                <p class="text-gray-400 text-xs truncate">{tool.tagline}</p>
              </div>
              <div class="flex-shrink-0 text-right">
                <p class="text-xs font-bold text-green-600">{tool.pricing_type}</p>
                <p class="text-xs text-gray-400">{tool.pricing.split("/")[0]}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- NEWSLETTER MID -->
    <section>
      <NewsletterSignup variant="light" />
    </section>

    <!-- RELATED TEMPLATES -->
    {relatedTemplates.length > 0 && (
      <section>
        <h2 class="text-2xl font-extrabold text-[#1A2F4E] mb-6">Related Templates</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {relatedTemplates.map((rt) => (
            <a href={"/templates/" + rt.slug} class="bg-gray-50 border border-gray-200 hover:border-[#0ABFB8] rounded-2xl p-5 transition-all group">
              <div class="flex flex-wrap gap-2 mb-3">
                <span class="text-xs font-bold px-2.5 py-1 rounded-full text-white" style={"background-color: " + rt.badgeColor}>{rt.badge}</span>
                <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded font-medium">{rt.type}</span>
              </div>
              <h3 class="font-extrabold text-[#1A2F4E] group-hover:text-[#0ABFB8] text-base mb-1 transition-colors">{rt.title}</h3>
              <p class="text-gray-500 text-sm">{rt.tagline}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- RELATED SYSTEMS -->
    {relatedSystems.length > 0 && (
      <section>
        <h2 class="text-2xl font-extrabold text-[#1A2F4E] mb-2">Related Systems</h2>
        <p class="text-gray-500 text-sm mb-5">Take this template further with a complete business system:</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {relatedSystems.map((rs) => (
            <a href={"/systems/" + rs.slug} class="bg-white border border-gray-200 hover:border-[#0ABFB8] rounded-2xl p-5 transition-all group flex items-start gap-4">
              <div class="w-10 h-10 bg-[#1A2F4E] rounded-xl flex items-center justify-center text-[#0ABFB8] font-extrabold flex-shrink-0">S</div>
              <div>
                <h3 class="font-extrabold text-[#1A2F4E] group-hover:text-[#0ABFB8] text-sm mb-1 transition-colors">{rs.title}</h3>
                <p class="text-gray-400 text-xs">{rs.tagline}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>

  <!-- NEWSLETTER STRIP -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <NewsletterSignup variant="teal" />
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="py-14 bg-[#1A2F4E]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-3">Want us to implement this for you?</h2>
      <p class="text-gray-300 mb-6">Our Automation and AI specialists set up the template in your exact tools and workflow. Fixed price. No commitment required.</p>
      <a href="/setup" class="inline-block bg-[#0ABFB8] hover:bg-[#09A8A2] text-white font-bold px-8 py-4 rounded-xl transition-colors">Request Setup Quote</a>
    </div>
  </section>

</Layout>

<script is:inline>
  (function () {
    var btns = document.querySelectorAll(".ml-newsletter-btn");
    btns.forEach(function (btn) {
      if (!btn.dataset.bound) {
        btn.dataset.bound = "true";
        btn.addEventListener("click", function () {
          if (typeof ml !== "undefined") {
            ml("show", "Z8IoNZ", true);
          } else {
            window.open("https://preview.mailerlite.io/forms/2189648/181888158855595828/share", "_blank");
          }
        });
      }
    });
  })();
</script>