---
import Layout from "../../layouts/Layout.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import templates from "../../data/templates.js";

const categories = [...new Set(templates.map((t) => t.category))];

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Free Business Automation and AI Templates",
  "description": "Free templates for MSMEs and solo entrepreneurs. Checklists, SOPs, spreadsheets and automation recipes. Download free. Start saving time today.",
  "url": "https://aherisystems.com/templates",
  "publisher": { "@type": "Organization", "name": "Aheri Systems", "url": "https://aherisystems.com" }
};
---

<Layout
  title="Free Business Automation Templates — Checklists, SOPs and Recipes"
  description="Free Automation and AI templates for MSMEs and solo entrepreneurs. Checklists, SOPs, spreadsheets and Zapier recipes. Download free and start saving time today."
>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <!-- BREADCRUMB -->
  <div class="bg-gray-50 border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 py-3">
      <p class="text-xs text-gray-400">
        <a href="/" class="hover:text-[#0ABFB8] transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-600 font-medium">Templates</span>
      </p>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-[#1A2F4E] pt-14 pb-16">
    <div class="max-w-5xl mx-auto px-4">
      <div class="max-w-3xl">
        <p class="text-xs font-bold text-[#0ABFB8] tracking-widest uppercase mb-4">Free Automation and AI Templates</p>
        <h1 class="text-4xl font-extrabold text-white leading-tight mb-4">
          Skip the setup.<br/>Download and implement today.
        </h1>
        <p class="text-gray-300 text-lg mb-8">
          Every template here is ready to use. Not a framework. Not a concept. An actual working document, checklist, SOP, or automation recipe you can implement in your business today. All free. All built for MSMEs and solo entrepreneurs.
        </p>
        <div class="flex flex-wrap gap-4">
          <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-lg px-4 py-2">
            <span class="font-extrabold text-white">{templates.length}</span>
            <span class="text-gray-400 text-sm">free templates</span>
          </div>
          <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-lg px-4 py-2">
            <span class="font-extrabold text-white">$0</span>
            <span class="text-gray-400 text-sm">to download all</span>
          </div>
          <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-lg px-4 py-2">
            <span class="font-extrabold text-white">30min</span>
            <span class="text-gray-400 text-sm">average implementation time</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FILTER -->
  <section class="bg-white border-b border-gray-100 py-3 sticky top-16 z-40">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex items-center gap-3 overflow-x-auto">
        <span class="text-xs font-bold text-gray-400 uppercase tracking-wide whitespace-nowrap flex-shrink-0">Filter:</span>
        <button class="tpl-filter flex-shrink-0 px-3 py-1.5 rounded-lg text-xs font-bold border bg-[#1A2F4E] text-white border-[#1A2F4E] transition-colors" data-filter="all">All Templates</button>
        {categories.map((cat) => (
          <button class="tpl-filter flex-shrink-0 px-3 py-1.5 rounded-lg text-xs font-bold border bg-white text-gray-600 border-gray-200 hover:border-[#0ABFB8] hover:text-[#0ABFB8] transition-colors" data-filter={cat}>{cat}</button>
        ))}
        <button class="tpl-filter flex-shrink-0 px-3 py-1.5 rounded-lg text-xs font-bold border bg-white text-gray-600 border-gray-200 hover:border-green-600 hover:text-green-600 transition-colors" data-filter="free">Free Only</button>
      </div>
    </div>
  </section>

  <!-- TEMPLATES GRID -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4">

      <p class="text-gray-500 text-sm mb-6">
        Showing <span id="tpl-count" class="font-bold text-[#1A2F4E]">{templates.length}</span> templates
      </p>

      <div id="tpl-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {templates.map((tpl) => (
          <div
            class="tpl-card bg-white border border-gray-200 rounded-2xl p-6 hover:border-[#0ABFB8] hover:shadow-lg transition-all flex flex-col"
            data-category={tpl.category}
            data-free={tpl.free ? "true" : "false"}
          >
            <!-- Header -->
            <div class="flex items-start justify-between mb-4">
              <div class="flex flex-col gap-2">
                <span class="text-xs font-bold px-2.5 py-1 rounded-full text-white inline-block w-fit" style={"background-color: " + tpl.badgeColor}>{tpl.badge}</span>
                <div class="flex gap-2">
                  <span class="text-xs bg-gray-50 text-gray-600 border border-gray-200 px-2 py-0.5 rounded font-medium">{tpl.type}</span>
                  <span class="text-xs bg-gray-50 text-gray-600 border border-gray-200 px-2 py-0.5 rounded font-medium">{tpl.format}</span>
                  {tpl.free && <span class="text-xs bg-green-50 text-green-700 border border-green-200 px-2 py-0.5 rounded font-bold">Free</span>}
                </div>
              </div>
            </div>

            <h2 class="font-extrabold text-[#1A2F4E] text-lg leading-tight mb-2">{tpl.title}</h2>
            <p class="text-gray-500 text-sm leading-relaxed mb-4 flex-1">{tpl.tagline}</p>

            <!-- Outcome bars -->
            <div class="space-y-2 mb-4">
              {[
                { label: "Save Time", score: tpl.outcomes.save_time.score, metric: tpl.outcomes.save_time.metric, color: "#0ABFB8" },
                { label: "Save Money", score: tpl.outcomes.save_money.score, metric: tpl.outcomes.save_money.metric, color: "#059669" },
                { label: "Make Money", score: tpl.outcomes.make_money.score, metric: tpl.outcomes.make_money.metric, color: "#D97706" },
              ].map((o) => (
                <div class="flex items-center gap-2">
                  <span class="text-gray-400 text-xs w-20 flex-shrink-0">{o.label}</span>
                  <div class="flex-1 bg-gray-100 rounded-full h-1.5">
                    <div class="h-1.5 rounded-full" style={"width: " + (o.score * 10) + "%; background-color: " + o.color}></div>
                  </div>
                  <span class="text-xs font-bold flex-shrink-0" style={"color: " + o.color}>{o.metric}</span>
                </div>
              ))}
            </div>

            <!-- Meta -->
            <div class="flex items-center gap-3 mb-5 text-xs text-gray-400">
              <span>Time to use: <strong class="text-gray-600">{tpl.time_to_use}</strong></span>
              <span>|</span>
              <span>Category: <strong class="text-gray-600">{tpl.category}</strong></span>
            </div>

            <!-- CTA -->
            <a href={"/templates/" + tpl.slug} class="block w-full text-center bg-[#1A2F4E] hover:bg-[#0ABFB8] text-white font-bold py-3 rounded-xl transition-colors text-sm">
              View and Download Free
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <NewsletterSignup variant="teal" />
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="py-14 bg-[#1A2F4E]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-3">Need a custom template for your business?</h2>
      <p class="text-gray-300 mb-6">Tell us what you need. Our Automation and AI specialists build custom templates, SOPs and workflows for your exact business.</p>
      <a href="/setup" class="inline-block bg-[#0ABFB8] hover:bg-[#09A8A2] text-white font-bold px-8 py-4 rounded-xl transition-colors">Request a Custom Template</a>
    </div>
  </section>

</Layout>

<script is:inline>
  (function () {
    var btns = document.querySelectorAll(".tpl-filter");
    var cards = document.querySelectorAll(".tpl-card");
    var countEl = document.getElementById("tpl-count");
    var active = "all";

    function filter() {
      var visible = 0;
      cards.forEach(function (card) {
        var show = false;
        if (active === "all") show = true;
        else if (active === "free") show = card.getAttribute("data-free") === "true";
        else show = card.getAttribute("data-category") === active;
        if (show) { card.classList.remove("hidden"); visible++; }
        else card.classList.add("hidden");
      });
      if (countEl) countEl.textContent = String(visible);
    }

    btns.forEach(function (btn) {
      btn.addEventListener("click", function () {
        active = btn.getAttribute("data-filter");
        btns.forEach(function (b) {
          b.classList.remove("bg-[#1A2F4E]", "text-white", "border-[#1A2F4E]");
          b.classList.add("bg-white", "text-gray-600", "border-gray-200");
        });
        btn.classList.remove("bg-white", "text-gray-600", "border-gray-200");
        btn.classList.add("bg-[#1A2F4E]", "text-white", "border-[#1A2F4E]");
        filter();
      });
    });
  })();
</script>