---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Submit a Tool — Add Your Business Tool to Aheri Systems"
  description="Submit your business automation or AI tool to the Aheri Systems directory. Free basic listing. Premium featured listings available. Reach thousands of MSMEs actively looking for solutions."
>

  <!-- BREADCRUMB -->
  <div class="bg-gray-50 border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 py-3">
      <p class="text-xs text-gray-400">
        <a href="/" class="hover:text-[#0ABFB8] transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-600 font-medium">Submit a Tool</span>
      </p>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-[#1A2F4E] pt-14 pb-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row items-start gap-10">

        <div class="flex-1">
          <p class="text-xs font-bold text-[#0ABFB8] tracking-widest uppercase mb-4">For Tool Vendors and Developers</p>
          <h1 class="text-4xl font-extrabold text-white leading-tight mb-4">
            Get your tool in front of<br/>thousands of business owners.
          </h1>
          <p class="text-gray-300 text-lg mb-8">
            Aheri Systems is the go-to Automation and AI resource for MSMEs and solo entrepreneurs across Africa and beyond. Every visitor is actively looking for tools that save time, cut costs and grow revenue. That is your audience.
          </p>
          <div class="grid grid-cols-2 gap-4">
            {[
              { value: "2,400+", label: "Tools in directory" },
              { value: "10,000+", label: "Monthly visitors" },
              { value: "MSMEs", label: "Core audience" },
              { value: "48hrs", label: "Free listing goes live" },
            ].map((stat) => (
              <div class="bg-white/5 border border-white/10 rounded-xl p-4">
                <p class="font-extrabold text-[#0ABFB8] text-xl mb-1">{stat.value}</p>
                <p class="text-gray-400 text-xs">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Listing tiers -->
        <div class="w-full lg:w-80 flex-shrink-0 space-y-4">

          <div class="bg-white rounded-2xl p-5">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-extrabold text-[#1A2F4E] text-base">Basic Listing</h3>
              <span class="text-xl font-extrabold text-[#1A2F4E]">Free</span>
            </div>
            <ul class="space-y-2 mb-4">
              {[
                "Listed in the directory",
                "Category and tag placement",
                "Tool description and pricing",
                "Link to your website",
                "Goes live within 48 hours",
              ].map((item) => (
                <li class="flex items-center gap-2 text-xs text-gray-600">
                  <span class="text-[#0ABFB8] font-bold flex-shrink-0">✓</span>
                  {item}
                </li>
              ))}
            </ul>
            <p class="text-xs text-gray-400 text-center">Submit below. No payment required.</p>
          </div>

          <div class="bg-[#0ABFB8] rounded-2xl p-5">
            <div class="flex items-center justify-between mb-1">
              <h3 class="font-extrabold text-white text-base">Premium Featured</h3>
              <span class="text-xl font-extrabold text-white">$299/yr</span>
            </div>
            <p class="text-white/70 text-xs mb-3">Everything in Basic plus:</p>
            <ul class="space-y-2 mb-4">
              {[
                "Featured badge on your listing",
                "Top placement in your category",
                "Highlighted card design",
                "Included in weekly deals email",
                "Featured on homepage this week",
                "Goes live immediately",
              ].map((item) => (
                <li class="flex items-center gap-2 text-xs text-white">
                  <span class="font-bold flex-shrink-0">✓</span>
                  {item}
                </li>
              ))}
            </ul>
            <a href="mailto:hello@aherisystems.com?subject=Premium Featured Listing" class="block w-full text-center bg-[#1A2F4E] hover:bg-white hover:text-[#1A2F4E] text-white font-bold py-3 rounded-xl transition-colors text-sm">
              Get Featured Listing
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- FORM -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-2xl mx-auto px-4">

      <div class="text-center mb-10">
        <h2 class="text-2xl font-extrabold text-[#1A2F4E] mb-2">Submit Your Tool</h2>
        <p class="text-gray-500">Fill in the form below. We review every submission and respond within 48 hours.</p>
      </div>

      <form
        action="https://formspree.io/f/mkoqzqpk"
        method="POST"
        class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm space-y-5"
      >
        <input type="hidden" name="source" value="Submit a Tool Form" />
        <input type="hidden" name="_next" value="https://aherisystems.com/thank-you" />

        <!-- Tool basics -->
        <div>
          <h3 class="font-bold text-[#1A2F4E] text-sm uppercase tracking-wide mb-4">Tool Information</h3>
          <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1.5">Tool Name *</label>
                <input type="text" name="tool_name" required placeholder="e.g. Zapier" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1.5">Website URL *</label>
                <input type="url" name="website_url" required placeholder="https://yourtool.com" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1.5">One-line tagline *</label>
              <input type="text" name="tagline" required placeholder="What does your tool do in one sentence?" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]" />
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1.5">Full description *</label>
              <textarea name="description" required rows="4" placeholder="Describe your tool in 2-3 sentences. What problem does it solve? Who is it for? What makes it different?" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0ABFB8] resize-none"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1.5">Category *</label>
                <select name="category" required class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]">
                  <option value="">Select category</option>
                  <option>Automation and Workflow</option>
                  <option>AI Tools</option>
                  <option>CRM and Sales</option>
                  <option>Email Marketing</option>
                  <option>Project Management</option>
                  <option>Finance and Invoicing</option>
                  <option>Content Creation</option>
                  <option>Social Media</option>
                  <option>Customer Support</option>
                  <option>HR and Team Management</option>
                  <option>Analytics and Reporting</option>
                  <option>Other</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1.5">Pricing model *</label>
                <select name="pricing_model" required class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]">
                  <option value="">Select pricing</option>
                  <option>Free</option>
                  <option>Freemium</option>
                  <option>Paid only</option>
                  <option>Pay per use</option>
                  <option>Lifetime deal</option>
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1.5">Starting price</label>
                <input type="text" name="starting_price" placeholder="e.g. Free / $9/mo" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1.5">Do you have an affiliate programme?</label>
                <select name="has_affiliate" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]">
                  <option value="">Select</option>
                  <option>Yes</option>
                  <option>No</option>
                  <option>In progress</option>
                </select>
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1.5">Affiliate programme URL (if yes)</label>
              <input type="url" name="affiliate_url" placeholder="https://yourtool.com/affiliates" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]" />
            </div>
          </div>
        </div>

        <!-- MSME suitability -->
        <div class="border-t border-gray-100 pt-5">
          <h3 class="font-bold text-[#1A2F4E] text-sm uppercase tracking-wide mb-4">MSME Suitability</h3>
          <div class="space-y-4">
            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1.5">Who is your tool best for?</label>
              <input type="text" name="best_for" placeholder="e.g. Solo entrepreneurs, small teams of 2-10 people, service businesses" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]" />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1.5">Does it work in Africa?</label>
                <select name="africa_ready" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]">
                  <option value="">Select</option>
                  <option>Yes — fully supported</option>
                  <option>Partial — some limitations</option>
                  <option>No</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1.5">Technical skill required?</label>
                <select name="technical_level" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]">
                  <option value="">Select</option>
                  <option>None — anyone can use it</option>
                  <option>Basic — some learning required</option>
                  <option>Intermediate — setup help needed</option>
                  <option>Advanced — technical users</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact -->
        <div class="border-t border-gray-100 pt-5">
          <h3 class="font-bold text-[#1A2F4E] text-sm uppercase tracking-wide mb-4">Your Contact Details</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1.5">Your Name *</label>
              <input type="text" name="contact_name" required placeholder="Jane Mwangi" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1.5">Email Address *</label>
              <input type="email" name="contact_email" required placeholder="jane@yourtool.com" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]" />
            </div>
          </div>
          <div class="mt-4">
            <label class="block text-xs font-semibold text-gray-700 mb-1.5">Listing type requested</label>
            <select name="listing_type" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-[#0ABFB8]">
              <option>Free Basic Listing</option>
              <option>Premium Featured Listing ($299/year)</option>
              <option>Category Sponsor ($499/year)</option>
            </select>
          </div>
        </div>

        <button type="submit" class="w-full bg-[#1A2F4E] hover:bg-[#0ABFB8] text-white font-extrabold py-4 rounded-xl transition-colors text-sm">
          Submit Tool for Review
        </button>
        <p class="text-center text-gray-400 text-xs">We review every submission and respond within 48 hours. Free listings take no more than 48 hours to go live.</p>

      </form>
    </div>
  </section>

  <!-- WHY LIST ON AHERI -->
  <section class="py-14 bg-white border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-extrabold text-[#1A2F4E] mb-8 text-center">Why list on Aheri Systems?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            title: "The right audience",
            desc: "Our visitors are MSMEs and solo entrepreneurs actively researching tools to buy. Not casual browsers. Buyers.",
            color: "#0ABFB8",
          },
          {
            title: "Africa-focused reach",
            desc: "The only major tools directory built with African and emerging market businesses in mind. An audience no one else is serving.",
            color: "#059669",
          },
          {
            title: "Honest editorial",
            desc: "We review tools independently. That credibility is what makes our recommendations convert. Your listing benefits from that trust.",
            color: "#D97706",
          },
        ].map((item) => (
          <div class="text-center">
            <div class="w-12 h-12 rounded-full mx-auto mb-4 flex items-center justify-center" style={"background-color: " + item.color + "20; border: 2px solid " + item.color + "40"}>
              <span class="font-extrabold text-lg" style={"color: " + item.color}>A</span>
            </div>
            <h3 class="font-extrabold text-[#1A2F4E] mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>