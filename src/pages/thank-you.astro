---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Request Received" description="We have received your setup request and will respond within 24 hours.">
  <section class="bg-gray-50 min-h-screen flex items-center justify-center py-20">
    <div class="max-w-lg mx-auto px-4 text-center">
      <div class="w-20 h-20 bg-[#0ABFB8]/10 border-2 border-[#0ABFB8] rounded-full flex items-center justify-center text-4xl mx-auto mb-6">
        &#10003;
      </div>
      <h1 class="text-3xl font-extrabold text-[#1A2F4E] mb-3">Request Received</h1>
      <p class="text-gray-500 text-lg mb-6">We have your setup request and will respond within 24 hours with a clear plan — no jargon, no sales pitch.</p>
      <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-8 text-left space-y-3">
        <div class="flex items-center gap-3">
          <span class="w-6 h-6 bg-[#0ABFB8] rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">1</span>
          <span class="text-gray-700 text-sm">You will receive a confirmation email shortly</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-6 h-6 bg-[#0ABFB8] rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">2</span>
          <span class="text-gray-700 text-sm">Our team reviews your request within 24 hours</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-6 h-6 bg-[#0ABFB8] rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">3</span>
          <span class="text-gray-700 text-sm">We send you a fixed-price quote — no hidden costs</span>
        </div>
      </div>
      <a href="/tools" class="inline-block bg-[#1A2F4E] hover:bg-[#0ABFB8] text-white font-extrabold px-8 py-3.5 rounded-xl transition-colors text-sm mb-4">
        Browse More Tools
      </a>
      <p class="text-gray-400 text-xs">Questions? Email us at hello@aherisystems.com</p>
    </div>
  </section>
</Layout>