---
import Layout from "../layouts/Layout.astro";
import QuizFinder from "../components/QuizFinder.astro";

const categories = [
  { name: "Automation & Workflow", icon: "&#9889;", count: 48, slug: "automation" },
  { name: "AI Tools", icon: "&#129302;", count: 62, slug: "ai-tools" },
  { name: "CRM & Sales", icon: "&#128188;", count: 34, slug: "crm-sales" },
  { name: "Email Marketing", icon: "&#9993;", count: 28, slug: "email-marketing" },
  { name: "Project Management", icon: "&#128203;", count: 41, slug: "project-management" },
  { name: "Finance & Invoicing", icon: "&#128176;", count: 22, slug: "finance" },
  { name: "Content Creation", icon: "&#9997;", count: 37, slug: "content" },
  { name: "Social Media", icon: "&#128241;", count: 19, slug: "social-media" },
];

const featuredTools = [
  { name: "Zapier", tagline: "Automate your work across 6,000+ apps", category: "Automation", rating: 4.8, pricing: "Free / $19.99mo", badge: "Most Popular", badgeColor: "#0ABFB8", slug: "zapier" },
  { name: "Make", tagline: "Visual automation platform for complex workflows", category: "Automation", rating: 4.7, pricing: "Free / $9mo", badge: "Best Value", badgeColor: "#059669", slug: "make" },
  { name: "Notion", tagline: "All-in-one workspace for notes, tasks and wikis", category: "Project Management", rating: 4.8, pricing: "Free / $8mo", badge: "Africa Ready", badgeColor: "#D97706", slug: "notion" },
  { name: "ConvertKit", tagline: "Email marketing built for creators and solopreneurs", category: "Email Marketing", rating: 4.6, pricing: "Free / $25mo", badge: "MSME Verified", badgeColor: "#0052CC", slug: "convertkit" },
];
---

<Layout title="Home" description="The platform to run your business smarter with automation and AI. Save time, save money, make money.">

  <!-- HERO -->
  <section class="bg-[#1A2F4E] pt-16 pb-20">
    <div class="max-w-4xl mx-auto px-4 text-center">

      <div class="inline-flex items-center gap-2 bg-[#0ABFB8]/10 border border-[#0ABFB8]/30 rounded-full px-4 py-1.5 mb-6">
        <span class="text-[#0ABFB8] text-xs font-semibold tracking-wide">2,400+ TOOLS &middot; 150+ SYSTEMS &middot; 50+ TEMPLATES</span>
      </div>

      <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-3">
        Run Your Business Smarter
      </h1>
      <p class="text-[#0ABFB8] text-2xl md:text-3xl font-bold mb-4">Save Time. Save Money. Make Money.</p>
      <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">
        The go-to platform for MSMEs and solo entrepreneurs. Find the right automation tools, ready-made systems, and templates — all in one place.
      </p>

      <!-- SEARCH BAR -->
      <div class="flex gap-2 max-w-2xl mx-auto mb-6">
        <input
          type="text"
          placeholder="Search tools, systems, or templates..."
          class="flex-1 px-5 py-4 rounded-xl bg-white text-gray-900 text-sm font-medium placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#0ABFB8] border border-gray-200"
        />
        <button class="bg-[#0ABFB8] hover:bg-[#09A8A2] text-white font-bold px-8 py-4 rounded-xl transition-colors text-sm whitespace-nowrap">
          Search
        </button>
      </div>

      <!-- OR divider -->
      <div class="flex items-center gap-4 max-w-sm mx-auto mb-5">
        <div class="flex-1 h-px bg-white/20"></div>
        <span class="text-white/50 text-xs font-medium">not sure what you need?</span>
        <div class="flex-1 h-px bg-white/20"></div>
      </div>

      <!-- QUIZ TOGGLE -->
      <button id="quiz-toggle" class="text-[#0ABFB8] border border-[#0ABFB8]/50 hover:bg-[#0ABFB8]/10 text-sm font-semibold px-6 py-3 rounded-lg transition-colors mb-8">
        Help me find the right solution — 4 quick questions
      </button>

      <!-- QUIZ -->
      <div id="quiz-wrapper" class="hidden mt-2 mb-8">
        <QuizFinder />
      </div>

      <!-- Fast path buttons -->
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/tools" class="bg-white/15 hover:bg-white/25 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors border border-white/20">All Tools</a>
        <a href="/systems" class="bg-white/15 hover:bg-white/25 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors border border-white/20">Systems</a>
        <a href="/templates" class="bg-white/15 hover:bg-white/25 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors border border-white/20">Templates</a>
        <a href="/compare" class="bg-white/15 hover:bg-white/25 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors border border-white/20">Compare Tools</a>
      </div>

    </div>
  </section>

  <!-- STATS STRIP -->
  <section class="bg-[#0ABFB8] py-5">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-8 md:gap-16">
        <div class="text-center">
          <span class="text-white font-extrabold text-2xl">2,400+</span>
          <p class="text-white/80 text-xs mt-0.5">Tools Reviewed</p>
        </div>
        <div class="text-center">
          <span class="text-white font-extrabold text-2xl">150+</span>
          <p class="text-white/80 text-xs mt-0.5">Business Systems</p>
        </div>
        <div class="text-center">
          <span class="text-white font-extrabold text-2xl">50+</span>
          <p class="text-white/80 text-xs mt-0.5">Free Templates</p>
        </div>
        <div class="text-center">
          <span class="text-white font-extrabold text-2xl">10,000+</span>
          <p class="text-white/80 text-xs mt-0.5">Business Owners Helped</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORY GRID -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-[#1A2F4E]">Browse by Category</h2>
        <p class="text-gray-500 mt-2">Find the right tool for every part of your business</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {categories.map((cat) => (
          <a href={`/category/${cat.slug}`} class="bg-white rounded-xl p-5 border border-gray-200 hover:border-[#0ABFB8] hover:shadow-md transition-all group">
            <div class="text-3xl mb-3" set:html={cat.icon}></div>
            <h3 class="font-semibold text-[#1A2F4E] text-sm group-hover:text-[#0ABFB8] transition-colors">{cat.name}</h3>
            <p class="text-gray-400 text-xs mt-1">{cat.count} tools</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED TOOLS -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between mb-10">
        <div>
          <h2 class="text-3xl font-bold text-[#1A2F4E]">Featured Tools</h2>
          <p class="text-gray-500 mt-1">Hand-picked and verified for MSMEs and solo entrepreneurs</p>
        </div>
        <a href="/tools" class="text-[#0ABFB8] hover:text-[#09A8A2] text-sm font-semibold transition-colors">View all tools &rarr;</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        {featuredTools.map((tool) => (
          <a href={`/tools/${tool.slug}`} class="bg-white border border-gray-200 rounded-xl p-5 hover:border-[#0ABFB8] hover:shadow-md transition-all group block">
            <div class="flex items-start justify-between mb-3">
              <div class="w-10 h-10 bg-[#1A2F4E] rounded-lg flex items-center justify-center text-white font-bold text-lg">
                {tool.name[0]}
              </div>
              <span class="text-xs font-semibold px-2 py-1 rounded-full text-white" style={`background-color: ${tool.badgeColor}`}>
                {tool.badge}
              </span>
            </div>
            <h3 class="font-bold text-[#1A2F4E] group-hover:text-[#0ABFB8] transition-colors">{tool.name}</h3>
            <p class="text-gray-500 text-xs mt-1 mb-3 leading-relaxed">{tool.tagline}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400 bg-gray-50 px-2 py-1 rounded">{tool.category}</span>
              <span class="text-xs font-semibold text-amber-500">★ {tool.rating}</span>
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <span class="text-xs font-medium text-gray-600">{tool.pricing}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- STACK OF THE WEEK -->
  <section class="py-16 bg-[#1A2F4E]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between gap-10">

        <div class="max-w-xl">
          <div class="inline-flex items-center gap-2 bg-[#0ABFB8]/10 border border-[#0ABFB8]/30 rounded-full px-3 py-1 mb-4">
            <span class="text-[#0ABFB8] text-xs font-bold tracking-widest">STACK OF THE WEEK</span>
          </div>
          <h2 class="text-3xl font-bold text-white mb-3">The Free Tools Stack for Solo Entrepreneurs</h2>
          <p class="text-gray-300 mb-6 leading-relaxed">Run your entire solo business for $0/month. This stack covers email, automation, CRM, invoicing, and project management — all on free plans.</p>
          <div class="flex gap-8 mb-8">
            <div>
              <p class="text-[#0ABFB8] font-extrabold text-2xl">$0</p>
              <p class="text-gray-400 text-xs mt-1">Monthly cost</p>
            </div>
            <div>
              <p class="text-[#0ABFB8] font-extrabold text-2xl">5</p>
              <p class="text-gray-400 text-xs mt-1">Tools in stack</p>
            </div>
            <div>
              <p class="text-[#0ABFB8] font-extrabold text-2xl">10hrs</p>
              <p class="text-gray-400 text-xs mt-1">Saved per week</p>
            </div>
          </div>
          <a href="/systems/free-solo-stack" class="inline-block bg-[#0ABFB8] hover:bg-[#09A8A2] text-white font-bold px-8 py-3 rounded-lg transition-colors text-sm">
            View Full Stack &rarr;
          </a>
        </div>

        <div class="flex flex-col gap-3 w-full md:w-80">
          {[
            "Notion — Project Management",
            "ConvertKit — Email Marketing",
            "Zapier — Automation",
            "Wave — Invoicing",
            "Crisp — Customer Chat"
          ].map((tool) => (
            <div class="flex items-center gap-3 bg-white/5 border border-white/10 rounded-lg px-4 py-3 hover:border-[#0ABFB8]/40 transition-colors">
              <span class="w-6 h-6 bg-[#0ABFB8] rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">✓</span>
              <span class="text-white text-sm">{tool}</span>
              <span class="ml-auto text-[#0ABFB8] text-xs font-bold">Free</span>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-[#1A2F4E] mb-4">Is your business tool missing?</h2>
      <p class="text-gray-500 mb-8 leading-relaxed">Submit a tool to the Aheri Systems directory and get in front of thousands of business owners actively looking for solutions.</p>
      <a href="/submit" class="inline-block bg-[#1A2F4E] hover:bg-[#0ABFB8] text-white font-bold px-8 py-4 rounded-xl transition-colors">
        Submit a Tool — It is Free
      </a>
    </div>
  </section>

</Layout>

<script>
  document.getElementById("quiz-toggle")?.addEventListener("click", () => {
    const wrapper = document.getElementById("quiz-wrapper");
    const btn = document.getElementById("quiz-toggle");
    if (wrapper && btn) {
      if (wrapper.classList.contains("hidden")) {
        wrapper.classList.remove("hidden");
        btn.textContent = "Close the finder";
      } else {
        wrapper.classList.add("hidden");
        btn.textContent = "Help me find the right solution — 4 quick questions";
      }
    }
  });
</script>